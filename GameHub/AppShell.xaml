<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GameHub.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
    xmlns:views="clr-namespace:GameHub.Views"
    xmlns:local="clr-namespace:GameHub"
    Title="GameHub">
    
    <FlyoutItem Title="Домашняя страница" Icon="home.png">
        <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage"/>
    </FlyoutItem>

    <FlyoutItem Title="ДнД" Icon="dnd.png">
        <ShellContent ContentTemplate="{DataTemplate views:DnDHubPage}" Route="DnDHubPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Шахматы" Icon="chess.png">
        <ShellContent ContentTemplate="{DataTemplate views:ChessHubPage}" Route="ChessHubPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Настольные игры" Icon="boardgames.png">
        <ShellContent ContentTemplate="{DataTemplate views:BoardGamesHubPage}" Route="BoardGamesHubPage"/>
    </FlyoutItem>

    <FlyoutItem Title="Инструменты" Icon="tools.png">
        <ShellContent ContentTemplate="{DataTemplate views:ToolsHubPage}" Route="ToolsHubPage"/>
    </FlyoutItem>

</Shell>
