<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.ChessHubPage"
             Title="Шахматы"
             xmlns:modules="clr-namespace:GameHub.Views.Modules"
             xmlns:views="clr-namespace:GameHub.Views" BackgroundColor="#98A9B9">
    <Grid >
     <Grid.ColumnDefinitions>

         <ColumnDefinition Width="*"/>

         <ColumnDefinition Width="8*"/>

         <ColumnDefinition Width="*"/>
     </Grid.ColumnDefinitions>
     <Border Padding="40" Grid.Column="1" BackgroundColor="White" Stroke="White" StrokeShape="RoundRectangle 10">
         <VerticalStackLayout >
         <modules:TimerView/>
                <modules:ChessCount/>
            </VerticalStackLayout>
     </Border>
 </Grid>
</ContentPage>