<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.ToolsHubPage"
             Title="ToolsHubPage"
             xmlns:modules="clr-namespace:GameHub.Views.Modules" BackgroundColor="#98A9B9">
    <Grid>
        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="*"/>

            <ColumnDefinition Width="8*"/>

            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Stroke="White" BackgroundColor="White" StrokeShape="RoundRectangle 10" Grid.Column="1">
            <VerticalStackLayout>
                <Label Text="Набор утилит" HorizontalOptions="Center"/>
                <Label Text="Все утилиты в одном месте" HorizontalOptions="Center" />
                <Grid ColumnSpacing="10" RowSpacing="10" Margin="20" Padding="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Text="Таймер" Command="{Binding TimerCommand}" Grid.Row="0" Grid.Column="0" BackgroundColor="#405163"/>
                    <Button Text="Кубик" Command="{Binding DiceCommand}" Grid.Row="0" Grid.Column="1" BackgroundColor="#405163"/>

                    <Button Text="Рандомайзер игроков" Command="{Binding GamerRandomCommand}" Grid.Row="1" Grid.Column="0" BackgroundColor="#405163"/>
                    <Button Text="Рандомайзер" Command="{Binding RandomCommand}" Grid.Row="1" Grid.Column="1" BackgroundColor="#405163"/>

                    <Button Text="Счетчик очков" Command="{Binding CountCommand}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" BackgroundColor="#405163"/>

                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>