<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.DnDHubPage"
             Title="DnD"
             xmlns:modules="clr-namespace:GameHub.Views.Modules"
             xmlns:local="clr-namespace:GameHub">
    <ScrollView BackgroundColor="#89A3B4">
        
       
    
    
        
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

            <Border Stroke="#89A3B4" StrokeShape="RoundRectangle 10" Grid.Column="1">
                <VerticalStackLayout Padding="30,60,30,30" Background="White" Grid.Column="1">

                    <modules:DiceView/>

                    <Label Text="Заметки" HorizontalOptions="Center" FontAttributes="Italic"/>

                    <Editor x:Name="editor" Placeholder="Введите вашу заметку" HeightRequest="100"/>

                    <Grid ColumnDefinitions="*, 30, *" Margin="0, 10">
                        <Button Grid.Column="0" Text="Сохранить" WidthRequest="120" Clicked="OnSaveButtonClicked" BackgroundColor="#798776"/>
                        <Button Grid.Column="2" Text="Удалить"  WidthRequest="120" Clicked="OnDeleteButtonClicked" BackgroundColor="DarkRed"/>
                    </Grid>

                    <Label Text="История заметок" HorizontalOptions="Center" FontAttributes="Italic" Margin="0,20,0,5"/>

                    <CollectionView x:Name="historyList" HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="LightGray" StrokeThickness="1" Padding="10" Margin="0,3" StrokeShape="RoundRectangle 6">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding Date}" FontSize="12" TextColor="Gray"/>
                                        <Label Text="{Binding Text}" FontSize="14"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>
        
    </ScrollView>
</ContentPage>