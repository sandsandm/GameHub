<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.DnDHubPage"
             Title="DnD"
             xmlns:modules="clr-namespace:GameHub.Views.Modules"
             xmlns:local="clr-namespace:GameHub">
    <ScrollView BackgroundColor="#89A3B4">
        <Border Stroke="#89A3B4">
            <Grid>
            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*" />

                <ColumnDefinition Width="8*" />

                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <VerticalStackLayout Padding="30,60,30,30" Background="#f6f7e9" Grid.Column="1">

                <modules:DiceView/>


                <Label Text="Заметки" HorizontalOptions="Center" FontAttributes="Italic"/>

                <Editor x:Name="editor" Placeholder="Введите вашу заметку" HeightRequest="100"/>

                    <Grid ColumnDefinitions="Auto, 30, Auto" Margin="0, 10">

                        <Button Grid.Column="0" Text="Сохранить" WidthRequest="100" Clicked="OnSaveButtonClicked" BackgroundColor="#94E4E1"/>

                        <Button Grid.Column="2" Text="Удалить"  WidthRequest="100" Clicked="OnDeleteButtonClicked" BackgroundColor="DarkRed"/>
                    </Grid>
                </VerticalStackLayout>
        </Grid>
        </Border>
    </ScrollView>
</ContentPage>