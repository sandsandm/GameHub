<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.AddTeamPage"
             Title="Добавить игрока">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">
            <Entry x:Name="TeamNameEntry" Placeholder="Название команды" />

            <Entry x:Name="PlayerEntry" Placeholder="Имя игрока" />
            <Button Text="Добавить игрока" Clicked="OnAddPlayerClicked" />

            <CollectionView x:Name="PlayersList" />

            <Button Text="Сохранить команду" Clicked="OnSaveTeamClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
