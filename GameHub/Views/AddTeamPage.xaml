<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.AddTeamPage"
             Title="Добавить команду" BackgroundColor="#1e3c72" >
    <ScrollView BackgroundColor="#94E4E1">
        <Grid>
            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="8*"/>

                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="1" BackgroundColor="#f6f7e9" Stroke="#f6f7e9" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout Padding="20" Spacing="10" >
                
                    
                <Entry x:Name="TeamNameEntry" Placeholder="Название команды" BackgroundColor="White"/>

                <Entry x:Name="PlayerEntry" Placeholder="Имя игрока" BackgroundColor="White" />
                    <Button Text="Добавить игрока" Clicked="OnAddPlayerClicked" BackgroundColor="#2dc8c3" />

                <CollectionView x:Name="PlayersList" />

                    <Button Text="Сохранить команду" Clicked="OnSaveTeamClicked" BackgroundColor="#2dc8c3" />
 
            </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
