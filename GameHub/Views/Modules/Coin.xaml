<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.Modules.Coin">
    
    <VerticalStackLayout>

        <Label Text="Монетка"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,20"/>
        
        <Label Text="{Binding Result}"
               FontSize="72"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,20,0,0"/>

        <Button Text="Сгенерировать"
                Command="{Binding FlipCommand}"
                BackgroundColor="#6A7F9A"
                TextColor="White"
                FontSize="20"
                FontAttributes="Bold"
                CornerRadius="10"
                HeightRequest="60"
                Margin="0,10,0,0"/>

        <Border StrokeShape="RoundRectangle 10"
                        BackgroundColor="White"
                        Margin="0,20,0,0">
            <VerticalStackLayout>
                <Label Text="История бросков:" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               Margin="10,10,10,5" />

                <ScrollView HeightRequest="120">
                    <Label Text="{Binding HistoryLabel}" 
                           FontSize="14"
                           Margin="10" />
                </ScrollView>
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentView>
