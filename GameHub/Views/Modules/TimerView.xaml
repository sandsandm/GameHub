<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.Modules.TimerView">
    <VerticalStackLayout>
        <Label Text="{Binding Title}" FontSize="24" HorizontalOptions="Center"/>
        <Label Text="{Binding DisplayTime}" FontSize="48" HorizontalOptions="Center" />

        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button Text="Start" Command="{Binding StartCommand}" />
            <Button Text="Pause" Command="{Binding PauseCommand}" />
            <Button Text="Reset" Command="{Binding ResetCommand}" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentView>
