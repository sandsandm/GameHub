<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.Modules.ScoreBoardView">

    <Border Stroke="#f6f7e9"
            BackgroundColor="#f6f7e9"
            StrokeThickness="1"
            Padding="10"
            StrokeShape="RoundRectangle 10">
        <CollectionView x:Name="TeamsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Spacing="6" Padding="10">

                       
                        <Grid ColumnDefinitions="*,100">
                            <Label Grid.Column="0"
                                   Text="{Binding Name}"
                                   VerticalOptions="Center"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="#5E5F71"/>
                            <Entry Grid.Column="1"
                                   Text="{Binding Score}"
                                   Keyboard="Numeric"
                                   TextChanged="OnScoreChanged" BackgroundColor="White" VerticalOptions="Center"/>
                        </Grid>
                        
                        <Label Text="Список команды" FontAttributes="Bold" FontSize="16"/>
                        
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 10">
                            
                            <CollectionView ItemsSource="{Binding Players}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    
                                        <Label Text="{Binding .}"
                                           FontSize="13"
                                           TextColor="#5E5F71" HeightRequest="30" VerticalOptions="Center"/>
                                    
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        </Border>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Border>

</ContentView>
