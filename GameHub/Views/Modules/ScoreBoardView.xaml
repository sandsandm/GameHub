<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.Modules.ScoreBoardView">

    <Border Stroke="Gray"
            StrokeThickness="1"
            Padding="10"
            StrokeShape="RoundRectangle 10">

        <CollectionView x:Name="TeamsList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="*,100">
                        <Label Grid.Column="0"
                               Text="{Binding Name}"
                               VerticalOptions="Center"
                               FontSize="16" />

                        <Entry Grid.Column="1"
                               Text="{Binding Score}"
                               Keyboard="Numeric"
                               TextChanged="OnScoreChanged" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Border>

</ContentView>
