<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.Modules.RandomizerView">

    <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">

        <Label Text="Рандомайзер"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,5"/>
        <Label Text="Выберите промежуток чисел"
               FontSize="20"
              
               HorizontalOptions="Center"
               TextColor="#676767"
               Margin="0,0,0,20"/>

        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="10">
            <Entry Grid.Column="1"
                   Text="{Binding MinValue}"
                   Keyboard="Numeric"
                   Placeholder="От"
                   BackgroundColor="#98A9B9"
                   
                   FontSize="18"
                   HorizontalTextAlignment="Center"/>

            <Label Grid.Column="2" 
                   Text="—" 
                   FontSize="24"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <Entry Grid.Column="3"
                   Text="{Binding MaxValue}"
                   Keyboard="Numeric"
                   Placeholder="До"
                   BackgroundColor="#98A9B9"
                   
                   FontSize="18"
                   HorizontalTextAlignment="Center"/>
        </Grid>

        <Label Text="{Binding RangeValidationMessage}"
               TextColor="DarkRed"
               FontSize="14"
               HorizontalOptions="Center"/>

        <Button Text="Сгенерировать"
                Command="{Binding GenerateRandomCommand}"
                BackgroundColor="#798776"
                TextColor="White"
                FontSize="20"
                FontAttributes="Bold"
                CornerRadius="10"
                HeightRequest="60"
                Margin="0,10,0,0"/>

        <Label Text="{Binding Result}"
               FontSize="72"
               FontAttributes="Bold"
               TextColor="#405163"
               HorizontalOptions="Center"
               Margin="0,20,0,0"
               IsVisible="{Binding IsResultVisible}"/>
    </VerticalStackLayout>
</ContentView>