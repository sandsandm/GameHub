<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.Modules.DiceView"
             >
    <ScrollView >
        
            
                
                
                <Border StrokeShape="RoundRectangle 10" Stroke="White" >
                    <VerticalStackLayout Padding="20" Spacing="15" HorizontalOptions="Center" BackgroundColor="White">

                        <Label Text="Вам выпало число:" 
                       FontSize="30" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center"
                       TextColor="Black" />

                        <Border Stroke="White"
                        HorizontalOptions="Center">
                            <Label x:Name="ResultLabel" 
                           Text="?" 
                           FontSize="72" 
                           FontAttributes="Bold"
                           TextColor="#5E5F71"
                           HorizontalOptions="Center" />
                        </Border>

                        <!-- Выбор количества граней -->
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="Грани:" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           VerticalOptions="Center"
                           TextColor="Black" />

                            <Picker x:Name="DiceTypePicker" 
                            
                            WidthRequest="150"
                            HeightRequest="30"
                            BackgroundColor="White"
                            TextColor="Black">
                                <Picker.Items>
                                    <x:String>D6 (6 граней)</x:String>
                                    <x:String>D12 (12 граней)</x:String>
                                    <x:String>D20 (20 граней)</x:String>
                                    <x:String>D25 (25 граней)</x:String>
                                </Picker.Items>
                                <Picker.SelectedIndex>
                                    0
                                </Picker.SelectedIndex>
                            </Picker>
                        </HorizontalStackLayout>

                        <Button x:Name="RollButton" 
                        Text="Бросить кубик" 
                        FontSize="24"
                        BackgroundColor="#98A9B9" 
                        TextColor="White"
                        CornerRadius="15"
                        HeightRequest="70"
                        Clicked="OnRollDiceClicked" />

                        <Border StrokeShape="RoundRectangle 10"
                        BackgroundColor="White"
                        Margin="0,20,0,0">
                            <VerticalStackLayout>
                                <Label Text="История бросков:" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               Margin="10,10,10,5" />

                                <ScrollView HeightRequest="120">
                                    <Label x:Name="HistoryLabel" 
                                   Text="Нет истории" 
                                   FontSize="14"
                                   Margin="10" />
                                </ScrollView>
                            </VerticalStackLayout>
                        </Border>

                        <Button x:Name="ClearHistoryButton" 
                        Text="Очистить историю" 
                        FontSize="16"
                        BackgroundColor="#676767" 
                        TextColor="White"
                        CornerRadius="10"
                        Clicked="OnClearHistoryClicked" />

                    </VerticalStackLayout>
                </Border>
           
       
    </ScrollView>
</ContentView>
