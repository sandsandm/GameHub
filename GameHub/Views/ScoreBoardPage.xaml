<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.ScoreBoardPage"
             Title="Счетчик очков"
             xmlns:modules="clr-namespace:GameHub.Views.Modules"  
             BackgroundColor="#98A9B9">
    <Grid >
        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="*"/>

            <ColumnDefinition Width="8*"/>

            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Border Padding="40" Grid.Column="1" BackgroundColor="White" Stroke="White" StrokeShape="RoundRectangle 10">
            <VerticalStackLayout Spacing="20" >
                <modules:ScoreBoardView/>
                <Label Text="Сначала создайте команду :P" TextColor="#676767" FontAttributes="Italic" FontSize="14" HorizontalOptions="Center"/>
                <Button Text="Создать команду" Command="{Binding OpenTeamCommand}" Grid.Row="1" Grid.Column="1" BackgroundColor="#798776"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>