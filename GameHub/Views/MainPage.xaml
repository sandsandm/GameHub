<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.MainPage"
             Title="Домашняя страница"
             xmlns:modules="clr-namespace:GameHub.Views.Modules">
    <VerticalStackLayout>
        
        <Grid  RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnDefinitions="Auto, Auto" HorizontalOptions="Center" ColumnSpacing="10" RowSpacing="10">
            <Label 
                Text="Популярные страницы"
                VerticalOptions="Center" 
                HorizontalOptions="Center" 
                Grid.Row="0"
                Grid.ColumnSpan="2"/>
            <Button Text="Открыть страницу шахмат" Command="{Binding OpenChessCommand}" Grid.Row="1" Grid.Column="0"/>
            <Button Text="Открыть страницу DnD" Command="{Binding OpenDnDCommand}" Grid.Row="1" Grid.Column="1"/>
        </Grid>
        
    </VerticalStackLayout>
</ContentPage>