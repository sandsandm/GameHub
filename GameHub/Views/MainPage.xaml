<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameHub.Views.MainPage"
             Title="Домашняя страница"
             xmlns:modules="clr-namespace:GameHub.Views.Modules">
    <FlexLayout Direction="Column"
    JustifyContent="SpaceEvenly"
    AlignItems="Center">
        
        <Label Text="Все игровые инструменты в одном хабе.Шахматы, DnD, настолки и командные игры. Таймеры, кубики, рандомайзер, счетчик очков и другое — всегда под рукой" 
               HorizontalOptions="Center"
               Margin="10"/>

        <Grid RowDefinitions="AUTO,auto,auto" ColumnDefinitions="Auto, Auto" HorizontalOptions="Center" ColumnSpacing="10" RowSpacing="10">
            <Button 
                  x:Name="CantinueBtn"
                  VerticalOptions="Center" 
                  HorizontalOptions="Center" 
                  Grid.Row="0"
                  Grid.ColumnSpan="2"
                 Command="{Binding ContinueCommand }"/>
        </Grid>
        
        <Grid  RowDefinitions="AUTO,auto,auto" ColumnDefinitions="Auto, Auto" HorizontalOptions="Center" ColumnSpacing="10" RowSpacing="10">
            <Label 
                Text="Популярные страницы"
                VerticalOptions="Center" 
                HorizontalOptions="Center" 
                Grid.Row="0"
                Grid.ColumnSpan="2"/>
            <Button Text="Открыть страницу шахмат" Command="{Binding OpenChessCommand}" Grid.Row="1" Grid.Column="0"/>
            <Button Text="Открыть страницу DnD" Command="{Binding OpenDnDCommand}" Grid.Row="1" Grid.Column="1"/>
            <Button Text="Открыть страницу настольных игр" Command="{Binding OpenBoardGamesCommand}" Grid.Row="2" Grid.Column="0"/>
            <Button Text="Определить команды" Command="{Binding OpenTeamCommand}" Grid.Row="2" Grid.Column="1" />
        </Grid>
        
        
        <Grid  RowDefinitions="auto,auto,auto" ColumnDefinitions="Auto, Auto" HorizontalOptions="Center" ColumnSpacing="10" RowSpacing="10" Margin="10">
            <Label 
                Text="Популярные утилиты"
                VerticalOptions="Center" 
                HorizontalOptions="Center" 
                Grid.Row="0"
                Grid.ColumnSpan="2"/>
            <Button Text="Бросить кубик " Command="{Binding OpenDiceCommand}" Grid.Row="1" Grid.Column="0"/>
            <Button Text="Рандомайзер игроков" Command="{Binding OpenGamerRandomCommand}" Grid.Row="1" Grid.Column="1"/>
            <Button Text="Включить таймер" Command="{Binding OpenTimerCommand}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"/>
        </Grid>

    </FlexLayout>
</ContentPage>